<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="8dp"
    android:background="@drawable/year_progress_widget_background"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/widget_year_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:fontFamily="monospace"
        android:maxLines="2"
        android:textColor="#FFFFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        tools:text="55% of 2026 has passed" />

    <TextView
        android:id="@+id/widget_days_left"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:fontFamily="monospace"
        android:maxLines="1"
        android:textColor="#FF888888"
        android:textSize="12sp"
        tools:text="164 days left" />

    <TextView
        android:id="@+id/widget_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:fontFamily="monospace"
        android:maxLines="1"
        android:textColor="#FF666666"
        android:textSize="12sp"
        tools:text="July 20" />

    <ProgressBar
        android:id="@+id/widget_year_progress_bar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="18dp"
        android:layout_marginTop="12dp"
        android:indeterminate="false"
        android:max="10000"
        android:progress="5500"
        android:progressDrawable="@drawable/year_progress_widget_bar"
        android:splitTrack="false" />

    <ImageView
        android:id="@+id/widget_year_overview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:adjustViewBounds="true"
        android:contentDescription="@null"
        android:scaleType="fitStart"
        android:visibility="gone"
        tools:visibility="visible" />
</LinearLayout>
